IDENTITY_HTTP_HOST=127.0.0.1
IDENTITY_HTTP_PORT=3000

IDENTITY_PERSISTENCE_BACKEND=memory
# IDENTITY_DATABASE_URL=postgres://identity:identity@localhost:5432/identity

IDENTITY_TOKEN_PRIVATE_KEY_PEM_PATH=./secrets/jwt_private.pem
IDENTITY_TOKEN_PUBLIC_KEY_PEM_PATH=./secrets/jwt_public.pem
IDENTITY_TOKEN_KEY_ID=mvp-local-key
IDENTITY_TOKEN_ISSUER=identity-service-local
IDENTITY_TOKEN_AUDIENCE=platform-api
IDENTITY_ACCESS_TOKEN_LIFETIME_SECONDS=900

IDENTITY_REFRESH_TOKEN_HMAC_SECRET=replace-with-a-long-local-secret
IDENTITY_REFRESH_TOKEN_LIFETIME_SECONDS=2592000
IDENTITY_SESSION_LIFETIME_SECONDS=2592000

IDENTITY_CLIENT_ID=identity-service-mvp
IDENTITY_CLIENT_TRUSTED_ORIGIN=http://localhost:3000

IDENTITY_PROVIDER_LOCAL_PASSWORD_ENABLED=true
IDENTITY_PROVIDER_SUPABASE_ENABLED=true
IDENTITY_PROVIDER_SUPABASE_AUTO_PROVISION_ENABLED=true
IDENTITY_PROVIDER_SUPABASE_PROJECT_URL=https://example.supabase.co
IDENTITY_PROVIDER_SUPABASE_ISSUER=https://example.supabase.co/auth/v1
IDENTITY_PROVIDER_SUPABASE_AUDIENCE=authenticated
IDENTITY_PROVIDER_SUPABASE_JWKS_URL=https://example.supabase.co/auth/v1/.well-known/jwks.json
# IDENTITY_PROVIDER_SUPABASE_JWKS_JSON=
IDENTITY_PROVIDER_SUPABASE_FIXTURE_TOKENS_ENABLED=false
