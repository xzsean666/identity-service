# Minimal local Docker/runtime configuration.
# Create a local .env from this template and adjust only what you need.

IDENTITY_REFRESH_TOKEN_HMAC_SECRET=replace-with-a-long-local-secret

# Frontend direct mode. Keep disabled for backend-only integration.
IDENTITY_FRONTEND_DIRECT_ENABLED=false
IDENTITY_FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWTs issued by this service. Other backends validate these values.
IDENTITY_TOKEN_ISSUER=http://127.0.0.1:3000
IDENTITY_TOKEN_AUDIENCE=platform-api
IDENTITY_TOKEN_KEY_ID=local-dev-key

# MVP defaults.
IDENTITY_PERSISTENCE_BACKEND=memory
IDENTITY_PROVIDER_LOCAL_PASSWORD_ENABLED=true
IDENTITY_PROVIDER_SUPABASE_ENABLED=false
