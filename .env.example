# Minimal local Docker/runtime configuration.
# Create a local .env from this template and adjust only what you need.

IDENTITY_REFRESH_TOKEN_HMAC_SECRET=change-this-to-a-random-32-byte-or-longer-secret

# Frontend direct mode. Keep disabled for backend-only integration.
IDENTITY_FRONTEND_DIRECT_ENABLED=false
IDENTITY_FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWTs issued by this service. Other backends validate these values.
IDENTITY_TOKEN_ISSUER=http://127.0.0.1:3000
IDENTITY_TOKEN_AUDIENCE=platform-api
IDENTITY_TOKEN_KEY_ID=local-dev-key

# MVP defaults.
IDENTITY_PERSISTENCE_BACKEND=memory
IDENTITY_PROVIDER_LOCAL_PASSWORD_ENABLED=true

# Supabase is part of the MVP, but disabled by default for local startup.
# To enable it, set enabled=true and fill only your Supabase Project ID.
# Do not put Supabase publishable/anon key or service_role key in this backend env for the MVP.
# The frontend uses the Supabase publishable key to get a Supabase access_token, then sends that token to this service.
IDENTITY_PROVIDER_SUPABASE_ENABLED=false
# IDENTITY_PROVIDER_SUPABASE_PROJECT_ID=ahjhppptrqnrhcpdpcew
# IDENTITY_PROVIDER_SUPABASE_AUTO_PROVISION_ENABLED=true
# IDENTITY_PROVIDER_SUPABASE_AUDIENCE=authenticated
# IDENTITY_PROVIDER_SUPABASE_FIXTURE_TOKENS_ENABLED=false

# Advanced only: use these when you need custom Supabase auth domains or manual JWKS.
# IDENTITY_PROVIDER_SUPABASE_PROJECT_URL=https://custom-auth.example.com
# IDENTITY_PROVIDER_SUPABASE_ISSUER=https://custom-auth.example.com/auth/v1
# IDENTITY_PROVIDER_SUPABASE_JWKS_URL=https://custom-auth.example.com/auth/v1/.well-known/jwks.json
